% Minimal NeurIPS 2023 style file (preprint option supported).
% Source: NeurIPS author kit (trimmed header comments). This file is provided
% here solely to enable local PDF compilation for the course project.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2023}[2023/09/01 NeurIPS 2023 style]

\RequirePackage{natbib}
\RequirePackage{geometry}
\RequirePackage{url}
\RequirePackage{xcolor}
\RequirePackage{hyperref}

\newif\if@neuripsfinal\@neuripsfinalfalse
\newif\if@neuripspreprint\@neuripspreprintfalse

\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripspreprinttrue}
\ProcessOptions\relax

\geometry{
  letterpaper,
  left=1in,
  right=1in,
  top=1in,
  bottom=1in
}

% Use standard plain page style to avoid extra dependencies (e.g., fancyhdr).
\pagestyle{plain}

\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue
}

\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}

% Title formatting
\renewcommand{\maketitle}{%
  \begin{center}
    {\LARGE \bfseries \@title \par}
    \vspace{0.5em}
    {\large \@author \par}
    \vspace{1em}
  \end{center}
}

% Natbib defaults similar to NeurIPS kits
\bibpunct{(}{)}{;}{a}{}{,}
\setcitestyle{authoryear,round}

